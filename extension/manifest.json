{
  "manifest_version": 3,
  "name": "QuickApply Autocompletar",
  "version": "0.1.0",
  "description": "Autocompleta formularios de empleo usando tu perfil de QuickApply.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["http://localhost:3000/*", "https://localhost:3000/*", "<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "QuickApply Autocompletar"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ]
}
